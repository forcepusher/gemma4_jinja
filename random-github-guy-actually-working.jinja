{%- set enable_thinking = true %}
{%- macro format_parameters(properties, required) -%}
    {%- set standard_keys = ['description', 'type', 'properties', 'required', 'nullable'] -%}
    {%- set ns = namespace(found_first=false) -%}
    {%- for key, value in properties | dictsort -%}
        {%- if value is mapping and key not in standard_keys -%}
            {%- set add_comma = false -%}
            {%- if ns.found_first %},{% endif -%}
            {%- set ns.found_first = true -%}
            {{ key }}:{
            {%- if value.get('description') -%}
                description:<|"|>{{ value.get('description') }}<|"|>
                {%- set add_comma = true -%}
            {%- endif -%}
            {%- if value.get('nullable') -%}
                {%- if add_comma %},{%- else -%}{%- set add_comma = true -%}{%- endif -%}
                nullable:true
            {%- endif -%}

            {%- set value_type = value.get('type', '') | string | upper -%}

            {%- if value_type == 'STRING' -%}
                {%- if value.get('enum') -%}
                    {%- if add_comma %},{%- else -%}{%- set add_comma = true -%}{%- endif -%}
                    enum:{{ format_argument(value.get('enum')) }}
                {%- endif -%}

            {%- elif value_type == 'OBJECT' -%}
                {%- if add_comma %},{%- else -%}{%- set add_comma = true -%}{%- endif -%}
                properties:{
                {%- if value.get('properties') is mapping -%}
                    {{- format_parameters(value.get('properties'), value.get('required', [])) -}}
                {%- endif -%}
                }
                {%- if value.get('required') -%}
                    ,required:[
                    {%- for item in value.get('required', []) -%}
                        <|"|>{{- item -}}<|"|>{% if not loop.last %},{% endif %}
                    {%- endfor -%}
                    ]
                {%- endif -%}

            {%- elif value_type == 'ARRAY' -%}
                {%- if value.get('items') is mapping and value.get('items') -%}
                    {%- if add_comma %},{%- else -%}{%- set add_comma = true -%}{%- endif -%}
                    items:{
                    {%- set ns_items = namespace(found_first=false) -%}
                    {%- for item_key, item_value in value.get('items', {}) | dictsort -%}
                        {%- if item_value is not none -%}
                            {%- if ns_items.found_first %},{% endif -%}
                            {%- set ns_items.found_first = true -%}

                            {%- if item_key == 'properties' -%}
                                properties:{
                                {%- if item_value is mapping -%}
                                    {{- format_parameters(item_value, value.get('items', {}).get('required', [])) -}}
                                {%- endif -%}
                                }

                            {%- elif item_key == 'required' -%}
                                required:[
                                {%- for req_item in item_value -%}
                                    <|"|>{{- req_item -}}<|"|>{% if not loop.last %},{% endif %}
                                {%- endfor -%}
                                ]

                            {%- elif item_key == 'type' -%}
                                {%- if item_value is string -%}
                                    type:{{ format_argument(item_value | upper) }}
                                {%- elif item_value is iterable and item_value is not string and item_value is not mapping -%}
                                    type:{{ format_argument(item_value | map('string') | map('upper') | list) }}
                                {%- endif -%}

                            {%- else -%}
                                {{ item_key }}:{{ format_argument(item_value) }}
                            {%- endif -%}
                        {%- endif -%}
                    {%- endfor -%}
                    }
                {%- endif -%}
            {%- endif -%}

            {%- if add_comma %},{%- endif -%}
            type:<|"|>{{ value_type }}<|"|>}
        {%- endif -%}
    {%- endfor -%}
{%- endmacro -%}

{%- macro format_function_declaration(tool_data) -%}
    {%- set fn = tool_data.get('function', {}) -%}
    declaration:{{- fn.get('name', '') -}}{description:<|"|>{{- fn.get('description', '') -}}<|"|>
    {%- set params = fn.get('parameters') -%}
    {%- if params is mapping -%}
        ,parameters:{
        {%- if params.get('properties') -%}
            properties:{ {{- format_parameters(params.get('properties', {}), params.get('required', [])) -}} }
        {%- endif -%}
        {%- if params.get('required') -%}
            {%- if params.get('properties') -%},{%- endif -%}
            required:[
            {%- for item in params.get('required', []) -%}
                <|"|>{{- item -}}<|"|>{% if not loop.last %},{% endif %}
            {%- endfor -%}
            ]
        {%- endif -%}
        {%- if params.get('type') -%}
            {%- if params.get('properties') or params.get('required') -%},{%- endif -%}
            type:<|"|>{{- params.get('type', '') | string | upper -}}<|"|>
        {%- endif -%}
        }
    {%- endif -%}

    {%- if fn.get('response') is mapping -%}
        {%- set response_declaration = fn.get('response', {}) -%}
        ,response:{
        {%- if response_declaration.get('description') -%}
            description:<|"|>{{- response_declaration.get('description') -}}<|"|>
            {%- if response_declaration.get('type') -%},{%- endif -%}
        {%- endif -%}
        {%- if response_declaration.get('type') -%}
            type:<|"|>{{- response_declaration.get('type', '') | string | upper -}}<|"|>
        {%- endif -%}
        }
    {%- endif -%}
    }
{%- endmacro -%}

{%- macro format_argument(argument, escape_keys=True) -%}
    {%- if argument is string -%}
        {{- '<|"|>' + argument + '<|"|>' -}}
    {%- elif argument is boolean -%}
        {{- 'true' if argument else 'false' -}}
    {%- elif argument is mapping -%}
        {{- '{' -}}
        {%- set ns = namespace(found_first=false) -%}
        {%- for key, value in argument | dictsort -%}
            {%- if ns.found_first %},{% endif -%}
            {%- set ns.found_first = true -%}
            {%- if escape_keys -%}
                {{- '<|"|>' + (key | string) + '<|"|>' -}}
            {%- else -%}
                {{- key | string -}}
            {%- endif -%}
            :{{- format_argument(value, escape_keys=escape_keys) -}}
        {%- endfor -%}
        {{- '}' -}}
    {%- elif argument is iterable and argument is not string and argument is not mapping -%}
        {{- '[' -}}
        {%- for item in argument -%}
            {{- format_argument(item, escape_keys=escape_keys) -}}
            {%- if not loop.last %},{% endif -%}
        {%- endfor -%}
        {{- ']' -}}
    {%- elif argument is none -%}
        null
    {%- else -%}
        {{- argument -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro strip_thinking(text) -%}
    {%- set ns = namespace(result='') -%}
    {%- for part in text.split('<channel|>') -%}
        {%- if '<|channel>' in part -%}
            {%- set ns.result = ns.result + part.split('<|channel>')[0] -%}
        {%- else -%}
            {%- set ns.result = ns.result + part -%}
        {%- endif -%}
    {%- endfor -%}
    {{- ns.result | trim -}}
{%- endmacro -%}

{%- set ns = namespace(prev_message_type=None) -%}
{%- set loop_messages = messages -%}
{{ bos_token }}

{#- Handle System/Tool Definitions Block -#}
{%- if (enable_thinking is defined and enable_thinking) or tools or (messages and messages[0].get('role') in ['system', 'developer']) -%}
    {{- '<|turn>system\n' -}}

    {%- if enable_thinking is defined and enable_thinking -%}
        {{- '<|think|>' -}}
        {%- set ns.prev_message_type = 'think' -%}
    {%- endif -%}

    {%- if messages and messages[0].get('role') in ['system', 'developer'] -%}
        {{- messages[0].get('content', '') | trim -}}
        {%- set loop_messages = messages[1:] -%}
    {%- endif -%}

    {%- if tools -%}
        {%- for tool in tools -%}
            {{- '<|tool>' -}}
            {{- format_function_declaration(tool) | trim -}}
            {{- '<tool|>' -}}
        {%- endfor -%}
        {%- set ns.prev_message_type = 'tool' -%}
    {%- endif -%}

    {{- '<turn|>\n' -}}
{%- endif -%}

{#- Loop through messages -#}
{%- for message in loop_messages -%}
    {%- set ns.prev_message_type = None -%}
    {%- set message_role = message.get('role', '') -%}
    {%- set role = 'model' if message_role == 'assistant' else message_role -%}
    {{- '<|turn>' + role + '\n' -}}

    {%- if message.get('tool_calls') -%}
        {%- for tool_call in message.get('tool_calls', []) -%}
            {%- set function = tool_call.get('function', {}) -%}
            {{- '<|tool_call>call:' + function.get('name', '') + '{' -}}
            {%- if function.get('arguments') is mapping -%}
                {%- set ns_args = namespace(found_first=false) -%}
                {%- for key, value in function.get('arguments', {}) | dictsort -%}
                    {%- if ns_args.found_first %},{% endif -%}
                    {%- set ns_args.found_first = true -%}
                    {{- key -}}:{{- format_argument(value, escape_keys=False) -}}
                {%- endfor -%}
            {%- elif function.get('arguments') is string -%}
                {{- function.get('arguments') -}}
            {%- endif -%}
            {{- '}<tool_call|>' -}}
        {%- endfor -%}
        {%- set ns.prev_message_type = 'tool_call' -%}
    {%- endif -%}

    {%- if message.get('tool_responses') -%}
        {%- for tool_response in message.get('tool_responses', []) -%}
            {{- '<|tool_response>' -}}
            {%- if tool_response.get('response') is mapping -%}
                {{- 'response:' + tool_response.get('name', 'unknown') + '{' -}}
                {%- for key, value in tool_response.get('response', {}) | dictsort -%}
                    {{- key -}}:{{- format_argument(value, escape_keys=False) -}}
                    {%- if not loop.last %},{% endif -%}
                {%- endfor -%}
                {{- '}' -}}
            {%- else -%}
                {{- 'response:' + tool_response.get('name', 'unknown') + '{value:' + format_argument(tool_response.get('response'), escape_keys=False) + '}' -}}
            {%- endif -%}
            {{- '<tool_response|>' -}}
        {%- endfor -%}
        {%- set ns.prev_message_type = 'tool_response' -%}
    {%- endif -%}

    {%- set content = message.get('content') -%}
    {%- if content is string -%}
        {%- if role == 'model' -%}
            {{- strip_thinking(content) -}}
        {%- else -%}
            {{- content | trim -}}
        {%- endif -%}
    {%- elif content is iterable and content is not string and content is not mapping -%}
        {%- for item in content -%}
            {%- if item.get('type') == 'text' -%}
                {%- if role == 'model' -%}
                    {{- strip_thinking(item.get('text', '')) -}}
                {%- else -%}
                    {{- item.get('text', '') | trim -}}
                {%- endif -%}
            {%- elif item.get('type') == 'image' -%}
                {{- '\n\n<|image|>\n\n' -}}
                {%- set ns.prev_message_type = 'image' -%}
            {%- elif item.get('type') == 'audio' -%}
                {{- '<|audio|>' -}}
                {%- set ns.prev_message_type = 'audio' -%}
            {%- elif item.get('type') == 'video' -%}
                {{- '\n\n<|video|>\n\n' -}}
                {%- set ns.prev_message_type = 'video' -%}
            {%- endif -%}
        {%- endfor -%}
    {%- endif -%}

    {%- if not (message.get('tool_responses') and not content) -%}
        {{- '<turn|>\n' -}}
    {%- endif -%}
{%- endfor -%}

{%- if add_generation_prompt -%}
    {%- if ns.prev_message_type != 'tool_response' -%}
        {{- '<|turn>model\n' -}}
    {%- endif -%}
    {%- if not enable_thinking | default(false) -%}
        {{- '<|channel>thought\n<channel|>' -}}
    {%- endif -%}
{%- endif -%}